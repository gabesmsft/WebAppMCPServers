{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources."
      }
    },
    "appServicePlanName": {
      "type": "string",
      "defaultValue": "mcpplan",
      "metadata": {
        "description": "Name of the App Service Plan."
      }
    },
    "webAppName": {
      "type": "string",
      "defaultValue": "[concat('builtinmcp-', toLower(uniqueString(resourceGroup().name)))]",
      "metadata": {
        "description": "Globally unique name of the Web App."
      }
    }
  },
  "variables": {
    "packageUrl": "https://raw.githubusercontent.com/gabesmsft/WebAppMCPServers/refs/heads/master/APIForBuiltInMCPServer/zip/apiforbuiltinmcp.zip"
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2022-09-01",
      "name": "[parameters('appServicePlanName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "B1",
        "tier": "Basic",
        "size": "B1",
        "capacity": 1
      },
      "properties": {
        "reserved": false
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2025-05-01",
      "name": "[parameters('webAppName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]"
      ],
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
        "autoGeneratedDomainNameLabelScope": "SubscriptionReuse",
        "aiIntegration": {
          "Mcp": {
            "Servers": [
              {
                "Name": "fruit orders",
                "Endpoint": "/fruit-mcp-server",
                "ApiSpecPath": "/home/site/wwwroot/.ai/spec.json"
              }
            ]
          }
        },
        "siteConfig": {
          "netFrameworkVersion": "v10.0",
          "appSettings": [
            {
              "name": "CURRENT_STACK",
              "value": "dotnet"
            },
            {
              "name": "WEBSITE_RUN_FROM_PACKAGE",
              "value": "[variables('packageUrl')]"
            }
          ]
        }
      }
    }
  ],
  "outputs": {
    "webAppUrl": {
      "type": "string",
      "value": "[concat('https://', parameters('webAppName'), '.azurewebsites.net')]"
    }
  }
}
