{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources."
      }
    },
    "appServicePlanName": {
      "type": "string",
      "defaultValue": "mcpplan",
      "metadata": {
        "description": "Name of the App Service Plan."
      }
    },
    "webAppName": {
      "type": "string",
      "defaultValue": "builtinmcpwebapp",
      "metadata": {
        "description": "Web App name"
      }
    }
  },
  "variables": {
    "packageUrl": "https://raw.githubusercontent.com/gabesmsft/WebAppMCPServers/refs/heads/master/APIForBuiltInMCPServer/zip/apiforbuiltinmcp.zip"
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2022-09-01",
      "name": "[parameters('appServicePlanName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "B1",
        "tier": "Basic",
        "size": "B1",
        "capacity": 1
      },
      "properties": {
        "reserved": false
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2025-05-01",
      "name": "[parameters('webAppName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]"
      ],
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
        "autoGeneratedDomainNameLabelScope": "SubscriptionReuse",
        "aiIntegration": {
          "ApiSpecPath": "/home/site/wwwroot/.ai/spec.json",
          "Mcp": {
            "Servers": [
              {
                "Name": "fruit orders",
                "Endpoint": "/fruit-mcp-server",
                "Description": "Fruit orders"
              }
            ]
          }
        },
        "siteConfig": {
          "netFrameworkVersion": "v10.0"
        }
      }
    },
    {
      "type": "Microsoft.Web/sites/config",
      "apiVersion": "2025-05-01",
      "name": "[concat(parameters('webAppName'), '/appsettings')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('webAppName'))]"
      ],
      "properties": "[union(reference(resourceId('Microsoft.Web/sites/config', parameters('webAppName'), 'appsettings'), '2025-05-01').properties, createObject('CURRENT_STACK', 'dotnet', 'WEBSITE_RUN_FROM_PACKAGE', variables('packageUrl')))]"
    }
  ],
  "outputs": {
    "webAppUrl": {
      "type": "string",
      "value": "[concat('https://', parameters('webAppName'), '.azurewebsites.net')]"
    }
  }
}
