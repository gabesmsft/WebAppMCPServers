{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources."
      }
    },
    "appServicePlanName": {
      "type": "string",
      "defaultValue": "mcpplan",
      "metadata": {
        "description": "Name of the App Service Plan."
      }
    },
    "webAppName": {
      "type": "string",
      "defaultValue": "byomcpwebapp",
      "metadata": {
        "description": "Web App name"
      }
    },
    "packageUrl": {
      "type": "string",
      "defaultValue": "https://raw.githubusercontent.com/gabesmsft/WebAppMCPServers/refs/heads/master/BYOMCPServer/zip/byomcpapp.zip",
      "metadata": {
        "description": "URL of the package to deploy."
      }
    }

  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2022-09-01",
      "name": "[parameters('appServicePlanName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "B1",
        "tier": "Basic",
        "size": "B1",
        "capacity": 1
      },
      "properties": {
        "reserved": false
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2025-05-01",
      "name": "[parameters('webAppName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]"
      ],
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
        "autoGeneratedDomainNameLabelScope": "SubscriptionReuse"
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "name": "readExistingAppSettings",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('webAppName'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "webAppName": {
              "type": "string"
            }
          },
          "resources": [],
          "outputs": {
            "existingAppSettings": {
              "type": "object",
              "value": "[list(resourceId('Microsoft.Web/sites/config', parameters('webAppName'), 'appsettings'), '2022-09-01').properties]"
            }
          }
        },
        "parameters": {
          "webAppName": {
            "value": "[parameters('webAppName')]"
          }
        }
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "name": "applyMergedAppSettings",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('webAppName'))]",
        "[resourceId('Microsoft.Resources/deployments', 'readExistingAppSettings')]"
      ],
      "properties": {
        "mode": "Incremental",
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "webAppName": {
              "type": "string"
            },
            "existingAppSettings": {
              "type": "object"
            },
            "packageUrl": {
              "type": "string"
            }
          },
          "resources": [
            {
              "type": "Microsoft.Web/sites/config",
              "apiVersion": "2022-09-01",
              "name": "[concat(parameters('webAppName'), '/appsettings')]",
              "properties": "[union(parameters('existingAppSettings'), createObject('CURRENT_STACK', 'dotnet', 'WEBSITE_RUN_FROM_PACKAGE', parameters('packageUrl')))]"
            }
          ]
        },
        "parameters": {
          "webAppName": {
            "value": "[parameters('webAppName')]"
          },
          "existingAppSettings": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', 'readExistingAppSettings'), '2022-09-01').outputs.existingAppSettings.value]"
          },
          "packageUrl": {
            "value": "[parameters('packageUrl')]"
          }
        }
      }
    }
  ]
}
